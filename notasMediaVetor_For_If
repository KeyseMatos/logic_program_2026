#include <stdio.h>

int main()
{
    float notas[5];
    float soma = 0;
    float media;
    
    for (int i = 0; i < 5; i++){
        
        printf("Digite uma nota: %d", i + 1);
        scanf("%.2f", &notas[i]);
        soma += notas[i];
    }
    
    media = soma / 5;
    
    for (int i = 0; i < 5; i++){
        printf("Notas: %f\n", notas[i]);
       
    }
    
    printf("Média: %.2f\n", media);
    
    if(media >= 6){
        printf("Aprovado");
    }else{
        printf("Reprovado");
}
    
    return 0;
}
